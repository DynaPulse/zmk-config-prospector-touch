if SHIELD_PROSPECTOR_TOUCH

config ZMK_KEYBOARD_NAME
    default "Prospector"

# --- Display stack (Zephyr 4.1 MIPI DBI + ST7789V) ---
config ZMK_DISPLAY
    default y

config DISPLAY
    default y

config SPI
    default y

config MIPI_DBI
    default y

config ST7789V
    default y

choice ST7789V_PIXEL_FORMAT
    default ST7789V_RGB565
endchoice

choice ZMK_DISPLAY_STATUS_SCREEN
    default ZMK_DISPLAY_STATUS_SCREEN_CUSTOM
endchoice

choice ZMK_DISPLAY_WORK_QUEUE
    default ZMK_DISPLAY_WORK_QUEUE_DEDICATED
endchoice

config ZMK_DISPLAY_DEDICATED_THREAD_STACK_SIZE
    default 16384

# --- LVGL ---
config LV_Z_MEM_POOL_SIZE
    default 32768

config LV_Z_DOUBLE_VDB
    default y

config LV_Z_VDB_SIZE
    default 30

config LV_DPI_DEF
    default 261

config LV_Z_BITS_PER_PIXEL
    default 16

choice LV_COLOR_DEPTH
    default LV_COLOR_DEPTH_16
endchoice

config LV_COLOR_16_SWAP
    default y

# --- Touch + pointing + sensors + backlight ---
config INPUT
    default y

config ZMK_POINTING
    default y

config I2C
    default y

config PWM
    default y

config LED
    default y

config PROSPECTOR_USE_AMBIENT_LIGHT_SENSOR
    select SENSOR
    select APDS9960

endif
